digraph "macres" {
node [
  fontsize = "12"
];
    "node9" [ label = "macres", shape = egg ];
    "node1" [ label = "SDL2::SDL2-static\n(SDL2::SDL2)", shape = octagon ];
    "node9" -> "node1" [ style = dotted ] // macres -> SDL2::SDL2-static
    "node2" [ label = "SDL2::SDL2main", shape = octagon ];
    "node9" -> "node2" [ style = dotted ] // macres -> SDL2::SDL2main
}
